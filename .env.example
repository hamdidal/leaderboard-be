# PostgreSQL — connection_limit prevents pool exhaustion under high traffic
DATABASE_URL=postgresql://panteon:panteon@localhost:5432/panteon_leaderboard?connection_limit=20&pool_timeout=10

# MongoDB
MONGODB_URI=mongodb://localhost:27017/panteon_leaderboard

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-random-32-plus-character-string-in-production
# Game-server → leaderboard ingest (min 32 chars; change in production)
INTERNAL_API_KEY=dev-internal-api-key-min-32-chars!!!
NODE_ENV=development
CRON_TIMEZONE=UTC
WEEKLY_CRON=0 0 * * 1
# Comma-separated allowed CORS origins (production only)
CORS_ORIGINS=https://yourdomain.com

# Client (Vite)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001/live
